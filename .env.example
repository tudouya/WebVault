# WebVault 管理员专用认证系统 - 环境变量配置示例
# 复制此文件到 .env.local 并填入实际值

# ============================================================================
# Clerk 身份认证配置（必需）
# ============================================================================
# 从你的Clerk仪表板获取这些值
# 文档: https://clerk.dev/docs/quickstarts/nextjs

# 你的Clerk公开密钥 (必需 - 前端使用)
# 这个密钥可以安全地暴露在浏览器中
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# 你的Clerk私有密钥 (必需 - 服务端使用)
# ⚠️ 警告：保持机密！仅在服务端代码中使用
# 此密钥用于：
# - 验证用户token
# - 服务端用户管理操作
# - 访问Clerk用户数据
CLERK_SECRET_KEY=sk_test_...

# ============================================================================
# Supabase 配置（必需） 
# ============================================================================
# 从你的Supabase项目仪表板获取这些值

# 你的Supabase项目URL (必需)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# 你的Supabase anon/public密钥 (必需) 
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 你的Supabase service role密钥 (必需 - 管理员专用系统)
# ⚠️ 警告：保持机密！仅在服务端代码和CLI工具中使用
# 此密钥用于：
# - 创建管理员账户 (通过CLI工具)
# - 服务端管理员操作
# - 绕过RLS策略进行数据库管理
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# Cloudflare D1 数据库配置（必需）
# ============================================================================
# 从你的Cloudflare仪表板获取这些值
# 文档: https://developers.cloudflare.com/d1/

# 你的D1数据库ID (必需)
# 从Cloudflare仪表板 > D1 > 选择数据库 > 设置中获取
CLOUDFLARE_D1_DATABASE_ID=your-database-id

# 你的Cloudflare账户ID (必需)  
# 从Cloudflare仪表板右侧边栏获取
CLOUDFLARE_ACCOUNT_ID=your-account-id

# 你的Cloudflare API令牌 (必需)
# ⚠️ 警告：保持机密！仅在服务端代码中使用
# 创建具有以下权限的API令牌：
# - Zone:Zone:Read
# - Account:D1:Edit  
# - Account:Cloudflare Workers:Edit
CLOUDFLARE_API_TOKEN=your-api-token

# ============================================================================
# 站点配置
# ============================================================================

# 你的站点URL (OAuth回调和重定向需要)
# 开发环境: http://localhost:3000  
# 生产环境: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================================
# 应用配置
# ============================================================================

# Next.js环境
NODE_ENV=development

# 应用URL (用于邮件模板和回调)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# 迁移完成 - 现在使用 Clerk + D1 技术栈
# ============================================================================

# 迁移已完成，现在直接使用：
# - 认证系统: Clerk
# - 数据库: Cloudflare D1 + Drizzle ORM
# - 不再需要 Supabase 相关配置（保留仅用于数据导出）

# ============================================================================
# 管理员CLI工具配置
# ============================================================================

# CLI工具日志级别 (error, warn, info, debug)
ADMIN_CLI_LOG_LEVEL=info

# 启用CLI操作审计日志
ADMIN_CLI_AUDIT_LOG=true

# CLI工具超时设置 (毫秒)
ADMIN_CLI_TIMEOUT=30000

# ============================================================================
# 开发和调试配置 (可选)
# ============================================================================

# 启用详细日志记录
DEBUG=false
VERBOSE_LOGGING=false

# 开发模式下的额外配置
DEV_SKIP_AUTH_CHECK=false
DEV_MOCK_ADMIN_USER=false

# ============================================================================
# 安全配置 (生产环境)
# ============================================================================

# 生产环境下，确保以下配置：
# NODE_ENV=production
# NEXT_PUBLIC_SITE_URL=https://your-production-domain.com
# NEXT_PUBLIC_APP_URL=https://your-production-domain.com
# DEBUG=false
# DEV_SKIP_AUTH_CHECK=false
# DEV_MOCK_ADMIN_USER=false