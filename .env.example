# WebVault 管理员专用认证系统 - 环境变量配置示例
# 复制此文件到 .env.local 并填入实际值

# ============================================================================
# Supabase 配置（必需） 
# ============================================================================
# 从你的Supabase项目仪表板获取这些值

# 你的Supabase项目URL (必需)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# 你的Supabase anon/public密钥 (必需) 
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 你的Supabase service role密钥 (必需 - 管理员专用系统)
# ⚠️ 警告：保持机密！仅在服务端代码和CLI工具中使用
# 此密钥用于：
# - 创建管理员账户 (通过CLI工具)
# - 服务端管理员操作
# - 绕过RLS策略进行数据库管理
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# 站点配置
# ============================================================================

# 你的站点URL (OAuth回调和重定向需要)
# 开发环境: http://localhost:3000  
# 生产环境: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================================
# 应用配置
# ============================================================================

# Next.js环境
NODE_ENV=development

# 应用URL (用于邮件模板和回调)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# 管理员CLI工具配置
# ============================================================================

# CLI工具日志级别 (error, warn, info, debug)
ADMIN_CLI_LOG_LEVEL=info

# 启用CLI操作审计日志
ADMIN_CLI_AUDIT_LOG=true

# CLI工具超时设置 (毫秒)
ADMIN_CLI_TIMEOUT=30000

# ============================================================================
# 开发和调试配置 (可选)
# ============================================================================

# 启用详细日志记录
DEBUG=false
VERBOSE_LOGGING=false

# 开发模式下的额外配置
DEV_SKIP_AUTH_CHECK=false
DEV_MOCK_ADMIN_USER=false

# ============================================================================
# 安全配置 (生产环境)
# ============================================================================

# 生产环境下，确保以下配置：
# NODE_ENV=production
# NEXT_PUBLIC_SITE_URL=https://your-production-domain.com
# NEXT_PUBLIC_APP_URL=https://your-production-domain.com
# DEBUG=false
# DEV_SKIP_AUTH_CHECK=false
# DEV_MOCK_ADMIN_USER=false