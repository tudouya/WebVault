# WebVault Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ============================================================================
# Supabase Configuration
# ============================================================================
# Get these values from your Supabase project dashboard at https://supabase.com

# Your Supabase project URL (required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here

# Your Supabase anon/public key (required)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Your Supabase service role key (optional, for admin operations)
# ⚠️ WARNING: Keep this secret! Only use in server-side code
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================================================
# Site Configuration
# ============================================================================

# Your site URL (required for OAuth callbacks)
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================================
# Development Configuration
# ============================================================================

# Next.js environment
NODE_ENV=development

# ============================================================================
# Optional: Third-party Services
# ============================================================================

# Screenshot API (for website previews)
# SCREENSHOT_API_KEY=your_screenshot_api_key

# Metadata extractor API
# METADATA_EXTRACTOR_API_KEY=your_metadata_api_key